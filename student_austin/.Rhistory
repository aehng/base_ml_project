idea <- both %>%
group_by(dteday) %>%
summarise(mean(predictions, na.rm = TRUE))
View(idea)
more_idea <- both %>%
left_join(idea, by = "dteday")
View(more_idea)
idea <- both %>%
group_by(dteday) %>%
summarise(daily_avg = mean(predictions, na.rm = TRUE))
more_idea <- both %>%
left_join(idea, by = "dteday")
more_idea <- both %>%
left_join(idea, by = "dteday") %>%
mutate(
base_rev = predictions*10,
adjusted_rev = ifelse(predictions >= daily_avg, 1.15*base_rev, base_rev)
)
more_idea <- both %>%
left_join(idea, by = "dteday") %>%
mutate(
base_rev = predictions*10,
adjusted_rev = ifelse(predictions >= daily_avg, 1.15*base_rev, base_rev),
date <- mdy(dteday)
)
